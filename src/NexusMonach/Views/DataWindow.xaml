<Window x:Class="NexusMonach.Views.DataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Данные браузера" Width="760" Height="560" MinWidth="570" MinHeight="400"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextBrush}"
        Icon="/Assets/nexus-monach.ico" WindowStartupLocation="CenterOwner" Style="{StaticResource GlassPopupWindow}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="HeaderText" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />
        <ListBox x:Name="ItemsList" Grid.Row="1" Background="#101923" BorderBrush="#2B4054"
                 Foreground="{StaticResource TextBrush}" MouseDoubleClick="ItemsList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="9,7">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding Primary}" FontWeight="SemiBold" FontSize="13"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1" Text="{Binding Secondary}" Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="11.5"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OpenButton" Content="Открыть" Padding="16,7" Margin="6,0"
                    Click="Open_Click" />
            <Button x:Name="ActionButton" Content="Удалить" Padding="16,7" Margin="6,0"
                    Click="Action_Click" />
            <Button Content="Закрыть" Padding="16,7" Margin="6,0" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
