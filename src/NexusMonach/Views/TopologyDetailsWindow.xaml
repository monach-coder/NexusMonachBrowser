<Window x:Class="NexusMonach.Views.TopologyDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сетевая топология" Width="650" Height="520" MinWidth="520" MinHeight="360"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextBrush}"
        Icon="/Assets/nexus-monach.ico" WindowStartupLocation="CenterOwner" Style="{StaticResource GlassPopupWindow}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Image Width="42" Height="42" Source="/Assets/nexus-monach-512.png" />
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="HeadingText" FontSize="19" FontWeight="SemiBold" />
                <TextBlock Text="Расширенные локальные сведения" Margin="0,3,0,0"
                           Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,16,0,12" Padding="12,9" Background="#10262B"
                BorderBrush="#2B7772" BorderThickness="1" CornerRadius="8">
            <TextBlock x:Name="SummaryText" TextWrapping="Wrap" Foreground="{StaticResource AccentBrush}" />
        </Border>

        <TextBox x:Name="DetailsTextBox" Grid.Row="2" IsReadOnly="True" AcceptsReturn="True"
                 TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Cascadia Mono, Consolas" FontSize="12" Padding="12" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Копировать" Padding="16,7" Margin="0,0,8,0" Click="Copy_Click" />
            <Button Content="Закрыть" Padding="18,7" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
