<Window x:Class="NexusMonach.Views.ExtensionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Расширения Nexus Monach" Width="760" Height="520" MinWidth="620" MinHeight="420"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextBrush}"
        Icon="/Assets/nexus-monach.ico" WindowStartupLocation="CenterOwner" Style="{StaticResource GlassPopupWindow}"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Расширения" FontSize="24" FontWeight="SemiBold" />
        <Border Grid.Row="1" Margin="0,12,0,14" Padding="12" CornerRadius="8"
                Background="#111E2B" BorderBrush="#2A465A" BorderThickness="1">
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                       Text="Поддерживаются распакованные Chromium-расширения из папки с manifest.json. Расширения, которым нужна собственная кнопка на панели Chrome или закрытые API Chrome Web Store, могут работать не полностью." />
        </Border>
        <ListView x:Name="ExtensionsList" Grid.Row="2" Background="#101923"
                  BorderBrush="#2B4054" Foreground="{StaticResource TextBrush}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название" Width="250" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="Состояние" Width="110" DisplayMemberBinding="{Binding State}" />
                    <GridViewColumn Header="ID" Width="310" DisplayMemberBinding="{Binding Id}" />
                </GridView>
            </ListView.View>
        </ListView>
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="Установить из папки…" Padding="16,7" HorizontalAlignment="Left"
                    Click="Install_Click" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Включить / выключить" Padding="16,7" Margin="6,0" Click="Toggle_Click" />
                <Button Content="Удалить" Padding="16,7" Margin="6,0" Click="Remove_Click" />
                <Button Content="Закрыть" Padding="16,7" Margin="6,0" Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
