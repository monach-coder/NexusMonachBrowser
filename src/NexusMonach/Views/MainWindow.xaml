<Window x:Class="NexusMonach.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:NexusMonach.Views"
        Title="Nexus Monach"
        Width="1280" Height="880" MinWidth="900" MinHeight="650"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        Icon="/Assets/nexus-monach.ico"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="54" />
            <RowDefinition Height="2" />
            <RowDefinition Height="*" />
            <RowDefinition Height="44" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <!-- Собственная верхняя панель без системных чёрных полос. -->
        <Grid x:Name="TitleBar" Grid.Row="0" Background="#0A0F17"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="38" />
                <ColumnDefinition Width="38" />
                <ColumnDefinition Width="38" />
            </Grid.ColumnDefinitions>
            <Grid.Resources>
                <Style x:Key="TitleButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButton}">
                    <Setter Property="Width" Value="34" />
                    <Setter Property="Height" Value="32" />
                    <Setter Property="Padding" Value="5" />
                    <Setter Property="FontSize" Value="11" />
                </Style>
            </Grid.Resources>

            <Image Grid.Column="0" Width="28" Height="28" Source="/Assets/nexus-monach-512.png"
                   ToolTip="Nexus Monach" />

            <ListBox x:Name="TabsList" Grid.Column="1"
                     ItemsSource="{Binding Tabs}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     PreviewMouseLeftButtonDown="TabsList_PreviewMouseLeftButtonDown"
                     ToolTip="Левый клик по свободному месту справа от вкладок создаёт новую"
                     SelectionChanged="TabsList_SelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="1,4,1,0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="TabBorder" Width="190" Height="38"
                                            Background="#0F1722" CornerRadius="9,9,0,0"
                                            BorderBrush="#172535" BorderThickness="1,1,1,0">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#172432" />
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#2D5660" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#1A2938" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10,0,4,0" Opacity="{Binding VisualOpacity}"
                              ToolTip="Неактивные вкладки постепенно затухают и выгружаются из памяти">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ShortTitle}"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                       FontFamily="Segoe UI" FontSize="12.5" />
                            <Button Grid.Column="1" Content="×" Tag="{Binding}"
                                    Style="{StaticResource IconButton}" FontFamily="Segoe UI"
                                    FontSize="18" Padding="2" ToolTip="Закрыть вкладку"
                                    Click="CloseTab_Click" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border x:Name="PrivateBadge" Grid.Column="2" Margin="5,8,8,5" Padding="10,0"
                    CornerRadius="12" Background="#2C1D46" BorderBrush="#7653A6" BorderThickness="1"
                    Visibility="Collapsed">
                <TextBlock Text="ПРИВАТНО" FontSize="10" FontWeight="SemiBold"
                           Foreground="#D7C0FF" VerticalAlignment="Center" />
            </Border>

            <Button Grid.Column="3" Content="&#xE921;" Style="{StaticResource TitleButtonStyle}"
                    ToolTip="Свернуть" Click="Minimize_Click" />
            <Button x:Name="MaximizeButton" Grid.Column="4" Content="&#xE922;"
                    Style="{StaticResource TitleButtonStyle}" ToolTip="Развернуть"
                    Click="Maximize_Click" />
            <Button Grid.Column="5" Content="&#xE72C;" Style="{StaticResource TitleButtonStyle}"
                    Foreground="{StaticResource AccentBrush}" ToolTip="Перезапустить Nexus Monach"
                    Click="RestartWindow_Click" />
        </Grid>

        <Grid Grid.Row="1" Background="#121A26" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="44" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton" Grid.Column="0" Content="&#xE72B;"
                    Style="{StaticResource IconButton}" ToolTip="Назад (Alt+←)" Click="Back_Click" />
            <Button x:Name="ForwardButton" Grid.Column="1" Content="&#xE72A;"
                    Style="{StaticResource IconButton}" ToolTip="Вперёд (Alt+→)" Click="Forward_Click" />
            <Button x:Name="ReloadButton" Grid.Column="2" Content="&#xE72C;"
                    Style="{StaticResource IconButton}" ToolTip="Обновить / остановить (F5)" Click="Reload_Click" />
            <Button Grid.Column="3" Content="&#xE80F;"
                    Style="{StaticResource IconButton}" ToolTip="Домой" Click="Home_Click" />

            <Border x:Name="AddressBorder" Grid.Column="4" Margin="5,8" CornerRadius="18"
                    Background="#0B121B" BorderBrush="#2C4056" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="38" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ConnectionGlyph" Grid.Column="0" Text="&#xE72E;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                               HorizontalAlignment="Center" ToolTip="Сведения о соединении" />
                    <TextBox x:Name="AddressBox" Grid.Column="1" BorderThickness="0" Background="Transparent"
                             Padding="2,7" VerticalContentAlignment="Center"
                             KeyDown="AddressBox_KeyDown" GotKeyboardFocus="AddressBox_GotKeyboardFocus" />
                    <Button Grid.Column="2" Content="&#xE721;" Style="{StaticResource IconButton}"
                            Padding="3" ToolTip="Перейти / искать" Click="SearchButton_Click" />
                </Grid>
            </Border>

            <Button x:Name="BookmarkButton" Grid.Column="5" Content="&#xE734;"
                    Style="{StaticResource IconButton}" ToolTip="Добавить в закладки (Ctrl+D)"
                    Click="Bookmark_Click" />

            <Button Grid.Column="6" Content="RU" Style="{StaticResource IconButton}" FontFamily="Segoe UI"
                    FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource GoldBrush}"
                    ToolTip="Локальный перевод страницы или звука видео" Click="TranslateMenu_Click">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Перевести страницу" Click="TranslateTop_Click" />
                        <MenuItem Header="Переводить звук видео в RU-субтитры" Click="TranslateVideoAudio_Click" />
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
            <Button Grid.Column="7" Content="AI" Style="{StaticResource IconButton}" FontFamily="Segoe UI"
                    FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"
                    ToolTip="Nexus Следопыт: найти, проверить и сравнить информацию" Click="ShoppingAgentTop_Click" />

            <Button Grid.Column="8" Content="&gt;_" Style="{StaticResource IconButton}"
                    FontFamily="Cascadia Mono, Consolas" FontSize="12" FontWeight="SemiBold"
                    Foreground="{StaticResource AccentBrush}" ToolTip="SSH-терминал Linux"
                    Click="SshTerminal_Click" />

            <Button x:Name="MenuButton" Grid.Column="9" Content="&#xE712;"
                    Style="{StaticResource IconButton}" ToolTip="Меню" Click="MenuButton_Click">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Новая вкладка" InputGestureText="Ctrl+T" Click="NewTab_Click" />
                        <MenuItem Header="Новое приватное окно" InputGestureText="Ctrl+Shift+N" Click="NewPrivateWindow_Click" />
                        <Separator />
                        <MenuItem Header="Закладки" InputGestureText="Ctrl+Shift+B" Click="ShowBookmarks_Click" />
                        <MenuItem Header="Загрузки" InputGestureText="Ctrl+J" Click="ShowDownloads_Click" />
                        <MenuItem Header="Умные капсулы вкладок" InputGestureText="Ctrl+Shift+K" Click="ShowSmartCapsules_Click" />
                        <MenuItem Header="Граф знаний и память просмотра" InputGestureText="Ctrl+Shift+G" Click="ShowKnowledgeGraph_Click" />
                        <Separator />
                        <MenuItem x:Name="ExtensionsMenuItem" Header="Расширения" Click="ShowExtensions_Click" />
                        <MenuItem Header="Показать / скрыть Privacy Dock" Click="ShowPrivacyMonitor_Click" />
                        <MenuItem Header="Инструменты разработчика" InputGestureText="F12" Click="ShowDeveloperTools_Click" />
                        <MenuItem Header="SSH-терминал Linux" Click="SshTerminal_Click" />
                        <MenuItem Header="Nexus Guardian · локальные рапорты" Click="ShowGuardianCenter_Click" />
                        <MenuItem Header="Настройки" Click="ShowSettings_Click" />
                        <MenuItem Header="Очистить данные просмотра" InputGestureText="Ctrl+Shift+Del" Click="ClearData_Click" />
                        <Separator />
                        <MenuItem Header="О браузере" Click="About_Click" />
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </Grid>

        <ProgressBar x:Name="LoadingBar" Grid.Row="2" Height="2" IsIndeterminate="True"
                     Foreground="{StaticResource AccentBrush}" Background="#13202B"
                     Visibility="Collapsed" />

        <Grid Grid.Row="3" Background="{StaticResource BackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ContentControl x:Name="BrowserHost" Grid.Column="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch" />
            <Border x:Name="TabLoadingOverlay" Grid.Column="0" Background="#0B1018" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Width="82" Height="82" Source="/Assets/nexus-monach-512.png" />
                    <TextBlock Text="Загрузка вкладки…" Margin="0,16,0,0"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="13" />
                </StackPanel>
            </Border>
            <views:LocalAiDockControl x:Name="LocalAiDock" Grid.Column="1" Visibility="Collapsed"
                                      HorizontalAlignment="Right" VerticalAlignment="Stretch" />
            <views:SshTerminalDockControl x:Name="SshTerminalDock" Grid.Column="1" Visibility="Collapsed"
                                          HorizontalAlignment="Right" VerticalAlignment="Stretch"
                                          CloseRequested="SshTerminal_CloseRequested" />
        </Grid>

        <Border Grid.Row="4" Background="#09111A" BorderBrush="#203747" BorderThickness="0,1,0,0"
                Padding="8,3">
            <Border.Resources>
                <Style x:Key="TopologyNodeButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
                    <Setter Property="Padding" Value="5,2" />
                    <Setter Property="FontFamily" Value="Segoe UI" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="ToolTip" Value="Нажмите для расширенных сведений" />
                </Style>
            </Border.Resources>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource TopologyNodeButton}" Click="BrowserNode_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="25" Height="25" Source="/Assets/nexus-monach-512.png" />
                        <TextBlock Text="NEXUS" Margin="5,0,0,0" VerticalAlignment="Center"
                                   FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                </Button>
                <Border Grid.Column="1" Height="2" Margin="6,0" Background="#2B6463" VerticalAlignment="Center" />

                <Button Grid.Column="2" Style="{StaticResource TopologyNodeButton}" Click="SystemRouteNode_Click">
                    <StackPanel>
                        <TextBlock Text="СИСТЕМНЫЙ МАРШРУТ" FontSize="7.8" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="Windows / VPN" FontSize="9.5" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Border Grid.Column="3" Height="2" Margin="6,0" Background="#2B6463" VerticalAlignment="Center" />

                <Button Grid.Column="4" Style="{StaticResource TopologyNodeButton}" Click="LocalPortsNode_Click">
                    <StackPanel>
                        <TextBlock Text="МОИ ПОРТЫ" FontSize="7.8" Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="TopologyLocalPortsText" Text="TCP — · UDP —" FontSize="9.5"
                                   Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Border Grid.Column="5" Height="2" Margin="6,0" Background="#2B6463" VerticalAlignment="Center" />

                <Button Grid.Column="6" Style="{StaticResource TopologyNodeButton}" Click="RoutingNode_Click">
                    <StackPanel>
                        <TextBlock Text="МАРШРУТИЗАЦИЯ" FontSize="7.8" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock x:Name="TopologyProxyText" Text="Прямое подключение" FontSize="9.5" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Border Grid.Column="7" Height="2" Margin="6,0" Background="#2B6463" VerticalAlignment="Center" />

                <Button Grid.Column="8" Style="{StaticResource TopologyNodeButton}" Click="InternetNode_Click">
                    <StackPanel>
                        <TextBlock Text="ИНТЕРНЕТ" FontSize="7.8" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="TLS / WebView2" FontSize="9.5" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Border Grid.Column="9" Height="2" Margin="6,0" Background="#2B6463" VerticalAlignment="Center" />

                <Button Grid.Column="10" Style="{StaticResource TopologyNodeButton}" Click="CurrentSiteNode_Click" MaxWidth="220">
                    <StackPanel>
                        <TextBlock Text="ТЕКУЩИЙ САЙТ" FontSize="7.8" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="TopologySiteText" Text="Новая вкладка" FontSize="9.5"
                                   TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <TextBlock x:Name="PrivacyLevelText" Grid.Column="11" Margin="8,0,0,0"
                           VerticalAlignment="Center" Foreground="{StaticResource GoldBrush}" FontSize="10" />
            </Grid>
        </Border>

        <views:PrivacyDockControl x:Name="PrivacyDock" Grid.Row="5" />

        <Border Grid.Row="6" Background="#122832" BorderBrush="#36D7C4" BorderThickness="0,2,0,0"
                Padding="14,7">
            <TextBlock x:Name="NetworkStatusText" FontSize="12"
                       FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                       ToolTip="↓/↑ — текущая скорость наиболее активного сетевого адаптера; PING LAN — локальная проверка шлюза Windows без внешнего запроса">
                <Run Text="СЕТЕВОЙ СТАТУС  ·  " />
                <Run x:Name="DownloadRateText" Text="↓ —" />
                <Run Text="  ·  " />
                <Run x:Name="UploadRateText" Text="↑ —" />
                <Run Text="  ·  " />
                <Run x:Name="PingText" Text="PING LAN —" />
                <Run x:Name="NetworkDetailsText" Text="  ·  подготовка…" />
            </TextBlock>
        </Border>
    </Grid>
</Window>
