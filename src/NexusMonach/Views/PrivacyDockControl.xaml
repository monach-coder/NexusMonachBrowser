<UserControl x:Class="NexusMonach.Views.PrivacyDockControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Height="72" Background="#0D151F" Loaded="Control_Loaded" Unloaded="Control_Unloaded">
    <Border BorderBrush="#294252" BorderThickness="0,1,0,0" Padding="10,5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="245" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,10,0">
                <TextBlock FontSize="11.5" FontWeight="SemiBold">
                    <Run Text="PRIVACY DOCK  ·  " Foreground="{StaticResource GoldBrush}" />
                    <Run x:Name="RiskText" Text="Запуск диагностики…" Foreground="{StaticResource AccentBrush}" />
                </TextBlock>
                <TextBlock x:Name="UpdatedText" Margin="0,4,0,0" FontSize="10.5"
                           Foreground="{StaticResource MutedTextBrush}" Text="Подготовка…" />
            </StackPanel>
            <Border Grid.Column="1" Background="#294252" />

            <StackPanel Grid.Column="2" Margin="10,0">
                <TextBlock x:Name="BrowserIpText" FontSize="11.5" Text="Локальный IP: —" />
                <TextBlock x:Name="DirectIpText" Margin="0,3,0,0" FontSize="11" Text="Маршрут: —" />
                <TextBlock x:Name="LocationText" Margin="0,2,0,0" FontSize="10.5"
                           TextTrimming="CharacterEllipsis" Foreground="{StaticResource MutedTextBrush}" Text="Среда Windows: —" />
            </StackPanel>
            <Border Grid.Column="3" Background="#294252" />

            <StackPanel Grid.Column="4" Margin="10,0">
                <TextBlock x:Name="FlagsText" FontSize="11" TextWrapping="Wrap" Text="VPN — · Proxy —" />
                <TextBlock x:Name="WebRtcText" Margin="0,4,0,0" FontSize="10.5"
                           TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Text="WebRTC: —" />
            </StackPanel>
            <Border Grid.Column="5" Background="#294252" />

            <StackPanel Grid.Column="6" Margin="10,0" MinWidth="220">
                <TextBlock x:Name="TransportText" FontSize="11" Text="Транспорт сайта: —" />
                <TextBlock x:Name="DnsText" Margin="0,2,0,0" FontSize="10.5" TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource MutedTextBrush}" Text="DNS Windows: —" />
                <TextBlock x:Name="MatchText" Margin="0,2,0,0" FontSize="10.5" TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource MutedTextBrush}" Text="Часовой пояс и язык: —" />
            </StackPanel>

            <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="↻" Width="32" Height="30" Padding="0" FontSize="15"
                        FontFamily="Segoe UI" Foreground="White" Background="#26FFFFFF"
                        Style="{StaticResource IconButton}" ToolTip="Обновить диагностику"
                        Click="Refresh_Click" />
                <Button Content="×" Width="32" Height="30" Padding="0" Margin="6,0,0,0" FontSize="15"
                        FontFamily="Segoe UI" Foreground="White" Background="#26FFFFFF"
                        Style="{StaticResource IconButton}"
                        ToolTip="Скрыть Privacy Dock" Click="Hide_Click" />
            </StackPanel>

            <wv2:WebView2 x:Name="NetworkProbe" Width="1" Height="1" IsHitTestVisible="False"
                          HorizontalAlignment="Left" VerticalAlignment="Bottom" />
        </Grid>
    </Border>
</UserControl>
