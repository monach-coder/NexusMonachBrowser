<Window x:Class="NexusMonach.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" Height="360" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False"
        ShowActivated="False" Topmost="True" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Storyboard x:Key="Pulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                             From="0.25" To="0.72" Duration="0:0:1.4" />
            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleX"
                             From="0.97" To="1.02" Duration="0:0:1.4" />
            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleY"
                             From="0.97" To="1.02" Duration="0:0:1.4" />
        </Storyboard>
    </Window.Resources>
    <Grid Loaded="Grid_Loaded">
        <Ellipse x:Name="Glow" Width="322" Height="322" Fill="#5036D7C4" />
        <Ellipse Width="294" Height="294" Fill="#F20B1018" Stroke="#5536D7C4" StrokeThickness="2" />
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Width="150" Height="150" Source="/Assets/nexus-monach-512.png"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" />
                </Image.RenderTransform>
            </Image>
            <TextBlock Text="NEXUS MONACH" Margin="0,14,0,0" Foreground="#EEF4F8"
                       FontSize="19" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="защищённый запуск" Margin="0,5,0,0" Foreground="#91A2B4"
                       FontSize="11" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
