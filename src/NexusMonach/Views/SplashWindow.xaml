<Window x:Class="NexusMonach.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" Height="360" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False"
        ShowActivated="False" Topmost="True" WindowStartupLocation="CenterScreen">
    <Grid Loaded="Grid_Loaded">
        <Ellipse Width="322" Height="322" Fill="#1836D7C4" />
        <Ellipse Width="308" Height="308" Fill="Transparent" Stroke="#3836D7C4" StrokeThickness="7" />
        <Path x:Name="CountdownRing" Stroke="#36D7C4" StrokeThickness="7"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
        <Ellipse Width="294" Height="294" Fill="#F20B1018" Stroke="#4036D7C4" StrokeThickness="2" />
        <Image Width="168" Height="168" Source="/Assets/nexus-monach-512.png"
               HorizontalAlignment="Center" VerticalAlignment="Center" />
        <!-- The countdown is conveyed only by the disappearing green ring. -->
        <TextBlock x:Name="CountdownText" Visibility="Collapsed" />
    </Grid>
</Window>
