<Window x:Class="NexusMonach.Views.SmartCapsulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Capsules" Width="760" Height="570" MinWidth="650" MinHeight="450"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextBrush}"
        Icon="/Assets/nexus-monach.ico" WindowStartupLocation="CenterOwner" Style="{StaticResource GlassPopupWindow}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="СЕМАНТИЧЕСКИЕ КАПСУЛЫ" FontSize="19" FontWeight="SemiBold" />
            <TextBlock Text="Автономный Nexus AI группирует открытые вкладки по смыслу. Архив сохраняет знания и закрывает вкладки."
                       Margin="0,5,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="310" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <ListBox x:Name="CapsulesList" SelectionChanged="CapsulesList_SelectionChanged"
                     Background="#0A121C" BorderBrush="#294252">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="8,6">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CountText}" Margin="0,3,0,0" FontSize="10"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Grid.Column="1" Margin="12,0,0,0" Padding="14" Background="#101B27"
                    BorderBrush="#294252" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock x:Name="CapsuleNameText" Text="Выбери капсулу" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock x:Name="CapsuleSummaryText" Grid.Row="1" Margin="0,7,0,0" TextWrapping="Wrap"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox x:Name="CapsuleItemsText" Grid.Row="2" Margin="0,10,0,0" IsReadOnly="True"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="ArchiveButton" Content="Архивировать в граф" Padding="16,8" Margin="0,0,8,0"
                    IsEnabled="False" Click="Archive_Click" />
            <Button Content="Закрыть" Padding="18,8" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
