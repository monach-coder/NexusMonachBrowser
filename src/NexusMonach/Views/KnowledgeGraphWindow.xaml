<Window x:Class="NexusMonach.Views.KnowledgeGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Локальный граф знаний" Width="1080" Height="720" MinWidth="800" MinHeight="520"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextBrush}"
        Icon="/Assets/nexus-monach.ico" WindowStartupLocation="CenterOwner" Style="{StaticResource GlassPopupWindow}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Image Width="38" Height="38" Source="/Assets/nexus-monach-512.png" />
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="PERSONAL KNOWLEDGE GRAPH" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock x:Name="StatsText" FontSize="10.5" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </StackPanel>
            <TextBox x:Name="SearchBox" Grid.Column="1" Margin="24,2" Padding="10,7"
                     Text="Поиск по смыслу, теме или URL" TextChanged="SearchBox_TextChanged"
                     GotKeyboardFocus="SearchBox_GotKeyboardFocus" />
            <Button Grid.Column="2" Content="Закрыть" Padding="16,7" Click="Close_Click" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>
            <Border Background="#081019" BorderBrush="#263E50" BorderThickness="1" CornerRadius="10">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Canvas x:Name="GraphCanvas" Width="1300" Height="900" Background="#081019" />
                </ScrollViewer>
            </Border>
            <Border Grid.Column="1" Margin="12,0,0,0" Padding="14" Background="#101B27"
                    BorderBrush="#263E50" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="NodeTitleText" Text="Выбери узел" FontSize="16" FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="NodeMetaText" Grid.Row="1" Margin="0,8,0,0" FontSize="10.5"
                               Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
                    <TextBox x:Name="NodeDetailsText" Grid.Row="2" Margin="0,12,0,0" Padding="10"
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                    <Button x:Name="OpenNodeButton" Grid.Row="3" Content="Открыть страницу"
                            Margin="0,12,0,0" Padding="14,8" IsEnabled="False" Click="OpenNode_Click" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
