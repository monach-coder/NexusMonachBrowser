<Window x:Class="NexusMonach.Views.KnowledgeGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Локальный граф знаний" Width="1240" Height="790" MinWidth="920" MinHeight="600"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextBrush}"
        Icon="/Assets/nexus-monach.ico" WindowStartupLocation="CenterOwner" Style="{StaticResource GlassPopupWindow}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Image Width="42" Height="42" Source="/Assets/nexus-monach-512.png" />
                <StackPanel Margin="11,0,0,0">
                    <TextBlock Text="NEXUS KNOWLEDGE CONSTELLATION" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Смысловая память просмотра · локально · без отдельной истории"
                               FontSize="10.5" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="28,0" VerticalAlignment="Center">
                <TextBlock x:Name="StatsText" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                <TextBlock x:Name="InsightText" Margin="0,3,0,0" FontSize="11.5" Foreground="{StaticResource GoldBrush}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <Button Grid.Column="2" Content="Закрыть" Padding="16,7" Click="Close_Click" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Padding="12,8" FontSize="13"
                     Text="Найти страницу по смыслу, теме, названию или URL"
                     TextChanged="SearchBox_TextChanged" GotKeyboardFocus="SearchBox_GotKeyboardFocus" />
            <ComboBox x:Name="PeriodBox" Grid.Column="1" Margin="10,0,0,0" Padding="8,6"
                      SelectedIndex="0" SelectionChanged="PeriodBox_SelectionChanged">
                <ComboBoxItem Content="За всё время" Tag="0" />
                <ComboBoxItem Content="Последние 24 часа" Tag="1" />
                <ComboBoxItem Content="Последние 7 дней" Tag="7" />
                <ComboBoxItem Content="Последние 30 дней" Tag="30" />
            </ComboBox>
            <Button Grid.Column="2" Content="Сбросить вид" Margin="10,0,0,0" Padding="13,7" Click="ResetView_Click" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>
            <Border Background="#70101010" BorderBrush="#66FFFFFF" BorderThickness="1" CornerRadius="14">
                <Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="GraphCanvas" Width="1720" Height="1080" Background="Transparent" />
                    </ScrollViewer>
                    <Border x:Name="EmptyPanel" Padding="22" CornerRadius="12" Background="#C0181818"
                            BorderBrush="#66FFFFFF" BorderThickness="1" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Visibility="Collapsed">
                        <StackPanel Width="360">
                            <TextBlock Text="Здесь появится твоя карта знаний" FontSize="18" FontWeight="SemiBold"
                                       TextAlignment="Center" />
                            <TextBlock Margin="0,9,0,0" TextWrapping="Wrap" TextAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Открывай обычные страницы. Локальные модели выделят темы, построят смысловые связи и сохранят маршруты между материалами." />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="12,0,0,0" Padding="15" Background="#70101010"
                    BorderBrush="#66FFFFFF" BorderThickness="1" CornerRadius="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="150" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="NodeTitleText" Text="Выбери созвездие или страницу" FontSize="17"
                               FontWeight="SemiBold" TextWrapping="Wrap" />
                    <WrapPanel Grid.Row="1" Margin="0,9,0,0">
                        <Border Padding="8,4" Margin="0,0,6,5" CornerRadius="8" Background="#20FFFFFF">
                            <TextBlock x:Name="NodeKindText" Text="узел" FontSize="10.5" Foreground="{StaticResource AccentBrush}" />
                        </Border>
                        <Border Padding="8,4" Margin="0,0,6,5" CornerRadius="8" Background="#20FFFFFF">
                            <TextBlock x:Name="NodeVisitsText" Text="0 посещений" FontSize="10.5" Foreground="{StaticResource GoldBrush}" />
                        </Border>
                    </WrapPanel>
                    <TextBox x:Name="NodeDetailsText" Grid.Row="2" Margin="0,9,0,0" Padding="10"
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" Background="#50101010" BorderBrush="#44FFFFFF"
                             Text="Поиск понимает не только слова, но и близкий смысл. Толстая линия означает сильную связь; пунктир — реальный переход между страницами." />
                    <TextBlock Grid.Row="3" Margin="0,11,0,5" Text="БЛИЖАЙШИЕ СВЯЗИ" FontSize="10"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <ListBox x:Name="RelatedList" Grid.Row="4" Background="#40101010" BorderBrush="#44FFFFFF"
                             DisplayMemberPath="Display" SelectionChanged="RelatedList_SelectionChanged"
                             MouseDoubleClick="RelatedList_MouseDoubleClick" />
                    <Grid Grid.Row="5" Margin="0,11,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <Button x:Name="PinNodeButton" Content="Закрепить" Padding="11,8" IsEnabled="False" Click="PinNode_Click" />
                        <Button x:Name="OpenNodeButton" Grid.Column="1" Content="Открыть страницу" Margin="8,0,0,0"
                                Padding="14,8" IsEnabled="False" Click="OpenNode_Click" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
